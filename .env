# ─── Database ───
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Google OAuth 2.0 SSO ───
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create a project (or use existing)
# 2. Enable "Google+ API" and "Google People API"
# 3. Create OAuth 2.0 Client ID (Web application type)
# 4. Add authorized redirect URI: https://your-domain.com/api/auth/google/callback
#    For local dev: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# Comma-separated list of allowed redirect origins. The callback URL is auto-derived.
# Example: http://localhost:3000,https://khojney.com
GOOGLE_REDIRECT_BASE=http://localhost:3000

# ─── NextAuth.js (for future use — Google provider already wired) ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-32-char-string
